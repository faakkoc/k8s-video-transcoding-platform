# API Gateway Configuration
# Copy this file to .env for local development outside Kubernetes
# In Kubernetes, these are set via ConfigMaps/Secrets (kubernetes/*/01-configmap.yaml)

# --- Settings (app/config.py) ---
APP_NAME=Video Transcoding API Gateway
APP_VERSION=0.1.0
API_PREFIX=/api/v1
MAX_UPLOAD_SIZE_MB=500

# --- Kubernetes ---
K8S_NAMESPACE=video-transcoding

# --- Storage Provider ---
# "gcs" -> GCSClient (Workload Identity, kein Secret nötig, nur auf GKE sinnvoll)
# "s3"  -> S3Client/boto3 (MinIO lokal, StackIT Object Storage)
STORAGE_PROVIDER=s3

INPUT_BUCKET=uploads
OUTPUT_BUCKET=outputs

# --- S3 / MinIO (nur bei STORAGE_PROVIDER=s3) ---
# Lokal: MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1

# StackIT Object Storage (Werte aus terraform/stackit output):
# S3_ENDPOINT=https://object.storage.eu01.onstackit.cloud
# S3_REGION=eu01
# S3_ACCESS_KEY=<terraform output object_storage_access_key>
# S3_SECRET_KEY=<terraform output object_storage_secret_key>

# --- GCS (nur bei STORAGE_PROVIDER=gcs, z.B. GKE) ---
# Keine S3_*-Variablen nötig — Authentifizierung läuft über Workload Identity
# (google.auth.default() in storage_client.GCSClient)

# --- Worker Job ---
TRANSCODING_WORKER_IMAGE=transcoding-worker:latest
IMAGE_PULL_POLICY=IfNotPresent
# IMAGE_PULL_SECRET=harbor-pull-secret   # nur StackIT (Harbor Robot Account)

# Worker-Credentials werden separat übergeben, damit sie nicht mit den
# API-Gateway-eigenen S3_* Variablen kollidieren (siehe k8s_client.py)
WORKER_S3_ACCESS_KEY=minioadmin
WORKER_S3_SECRET_KEY=minioadmin123
