# API Gateway Configuration
# Copy this file to .env for local development outside Kubernetes
# In Kubernetes, these are set via the deployment.yaml

# Application
APP_NAME=Video Transcoding API Gateway
APP_VERSION=0.1.0
DEBUG=false

# API Configuration
API_PREFIX=/api/v1
MAX_UPLOAD_SIZE_MB=500

# Kubernetes Configuration
KUBERNETES_NAMESPACE=video-transcoding
IN_CLUSTER=false          # Set to true when running inside Kubernetes
K8S_NAMESPACE=video-transcoding

# S3 / Object Storage Configuration
# Local development: MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1
INPUT_BUCKET=uploads
OUTPUT_BUCKET=outputs

# GCP (Cloud Storage) - set when deploying to GCP
# S3_ENDPOINT=https://storage.googleapis.com
# S3_ACCESS_KEY=        # Not needed with Workload Identity
# S3_SECRET_KEY=        # Not needed with Workload Identity

# StackIT Object Storage - set when deploying to StackIT
# S3_ENDPOINT=https://<stackit-object-storage-endpoint>
# S3_ACCESS_KEY=<stackit-access-key>
# S3_SECRET_KEY=<stackit-secret-key>

# Job Configuration
TRANSCODING_WORKER_IMAGE=transcoding-worker:latest
JOB_TTL_SECONDS=86400     # Jobs are cleaned up after 24 hours
